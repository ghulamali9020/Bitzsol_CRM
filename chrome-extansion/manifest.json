{
  "manifest_version": 3,
  "name": "Bitzsol CRM",
  "version": "1.0",
  "permissions": ["activeTab", "storage", "scripting", "cookies", "clipboardWrite"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://www.upwork.com/*",
    "https://www.fiverr.com/*",
    "https://yourcrm.com/*",
    "http://localhost:3000/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/in/*"],
      "js": ["content.js"]
    }
  ]
}
